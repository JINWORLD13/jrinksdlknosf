# Node.js 22 베이스 이미지 사용
FROM node:22-slim

# 작업 디렉토리 설정
WORKDIR /app

# Puppeteer/Chromium 실행에 필요한 시스템 라이브러리 설치
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libglib2.0-0 \
        libnspr4 \
        libnss3 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libx11-6 \
        libxcomposite1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libxcb1 \
        libxkbcommon0 \
        libasound2 \
        libcairo2 \
        libpango-1.0-0 \
        libpangocairo-1.0-0 \
        fonts-liberation \
        libappindicator3-1 \
        libx11-xcb1 \
        libxcursor1 \
        libxi6 \
        libxss1 \
        libxtst6 \
        libdrm2 \
        libxshmfence1 \
        xdg-utils \
        ca-certificates \
        wget \
        && \
    rm -rf /var/lib/apt/lists/*

# 루트 package.json과 yarn.lock 복사 (의존성 캐싱 최적화)
COPY package.json yarn.lock ./

# 루트 의존성 설치 (yarn 사용)
RUN yarn install --frozen-lockfile

# 프론트엔드 package.json과 package-lock.json 복사
COPY front/package.json front/package-lock.json ./front/

# 프론트엔드 의존성 설치
WORKDIR /app/front
RUN npm install --legacy-peer-deps


# 전체 소스 코드 복사
WORKDIR /app
COPY . .

# 프론트엔드 빌드 (react-spa-prerender 포함)
# VITE_SERVER_URL 환경 변수를 빌드 시 전달
# Railway Variables에서 설정된 값이 자동으로 빌드 시 사용됨
WORKDIR /app/front
# Railway가 빌드 시 환경 변수를 자동으로 전달하므로 ENV만 설정
# 기본값으로 https://cosmos-tarot.com 사용 (Railway Variables에서 덮어쓸 수 있음)
ARG VITE_SERVER_URL
ENV VITE_SERVER_URL=${VITE_SERVER_URL:-https://cosmos-tarot.com}

# Toss Payments Keys
ARG VITE_WIDGET_CLIENT_KEY_FOR_TOSS
ENV VITE_WIDGET_CLIENT_KEY_FOR_TOSS=$VITE_WIDGET_CLIENT_KEY_FOR_TOSS

ARG VITE_WIDGET_CLIENT_KEY_FOR_TOSS_PAYPAL
ENV VITE_WIDGET_CLIENT_KEY_FOR_TOSS_PAYPAL=$VITE_WIDGET_CLIENT_KEY_FOR_TOSS_PAYPAL

ARG VITE_WIDGET_CLIENT_KEY_FOR_TOSS_TEST
ENV VITE_WIDGET_CLIENT_KEY_FOR_TOSS_TEST=$VITE_WIDGET_CLIENT_KEY_FOR_TOSS_TEST

ARG VITE_WIDGET_CLIENT_KEY_FOR_TOSS_PAYPAL_TEST
ENV VITE_WIDGET_CLIENT_KEY_FOR_TOSS_PAYPAL_TEST=$VITE_WIDGET_CLIENT_KEY_FOR_TOSS_PAYPAL_TEST

ARG VITE_CUSTOMER_KEY_FOR_TOSS
ENV VITE_CUSTOMER_KEY_FOR_TOSS=$VITE_CUSTOMER_KEY_FOR_TOSS

ARG VITE_MUSIC_CDN_BASE
ENV VITE_MUSIC_CDN_BASE=${VITE_MUSIC_CDN_BASE:-https://cdn.pixabay.com}

ARG VITE_COS1
ENV VITE_COS1=$VITE_COS1


# Contact & Business Info
ARG VITE_ADMOB_CLIENT_ID
ENV VITE_ADMOB_CLIENT_ID=$VITE_ADMOB_CLIENT_ID

ARG VITE_COS2
ENV VITE_COS2=$VITE_COS2
ARG VITE_COS3
ENV VITE_COS3=$VITE_COS3
ARG VITE_COS4
ENV VITE_COS4=$VITE_COS4

ARG VITE_REPRESENTATIVE
ENV VITE_REPRESENTATIVE=$VITE_REPRESENTATIVE
ARG VITE_BIZ_REG_NO
ENV VITE_BIZ_REG_NO=$VITE_BIZ_REG_NO
ARG VITE_MAIL_ORDER_NO
ENV VITE_MAIL_ORDER_NO=$VITE_MAIL_ORDER_NO
ARG VITE_ADDRESS
ENV VITE_ADDRESS=$VITE_ADDRESS
ARG VITE_PHONE
ENV VITE_PHONE=$VITE_PHONE

# Product IDs (Vouchers)
ARG VITE_COSMOS_VOUCHERS_1
ENV VITE_COSMOS_VOUCHERS_1=$VITE_COSMOS_VOUCHERS_1
ARG VITE_COSMOS_VOUCHERS_2
ENV VITE_COSMOS_VOUCHERS_2=$VITE_COSMOS_VOUCHERS_2
ARG VITE_COSMOS_VOUCHER_3
ENV VITE_COSMOS_VOUCHER_3=$VITE_COSMOS_VOUCHER_3
ARG VITE_COSMOS_VOUCHERS_4
ENV VITE_COSMOS_VOUCHERS_4=$VITE_COSMOS_VOUCHERS_4
ARG VITE_COSMOS_VOUCHERS_5
ENV VITE_COSMOS_VOUCHERS_5=$VITE_COSMOS_VOUCHERS_5
ARG VITE_COSMOS_VOUCHERS_6
ENV VITE_COSMOS_VOUCHERS_6=$VITE_COSMOS_VOUCHERS_6
ARG VITE_COSMOS_VOUCHERS_7
ENV VITE_COSMOS_VOUCHERS_7=$VITE_COSMOS_VOUCHERS_7
ARG VITE_COSMOS_VOUCHERS_8
ENV VITE_COSMOS_VOUCHERS_8=$VITE_COSMOS_VOUCHERS_8
ARG VITE_COSMOS_VOUCHERS_9
ENV VITE_COSMOS_VOUCHERS_9=$VITE_COSMOS_VOUCHERS_9
ARG VITE_COSMOS_VOUCHER_10
ENV VITE_COSMOS_VOUCHER_10=$VITE_COSMOS_VOUCHER_10
ARG VITE_COSMOS_VOUCHERS_11
ENV VITE_COSMOS_VOUCHERS_11=$VITE_COSMOS_VOUCHERS_11
ARG VITE_COSMOS_VOUCHERS_13
ENV VITE_COSMOS_VOUCHERS_13=$VITE_COSMOS_VOUCHERS_13
ARG VITE_COSMOS_STAR_50
ENV VITE_COSMOS_STAR_50=$VITE_COSMOS_STAR_50
ARG VITE_COSMOS_VOUCHERS_ADS_REMOVER_3D
ENV VITE_COSMOS_VOUCHERS_ADS_REMOVER_3D=$VITE_COSMOS_VOUCHERS_ADS_REMOVER_3D
ARG VITE_COSMOS_VOUCHERS_EVENT_PACKAGE_EXPIRED
ENV VITE_COSMOS_VOUCHERS_EVENT_PACKAGE_EXPIRED=$VITE_COSMOS_VOUCHERS_EVENT_PACKAGE_EXPIRED

# Product IDs (Packages)
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_NEWBIE
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_NEWBIE=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_NEWBIE
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_1
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_1=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_1
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_2
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_2=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_2
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_3
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_3=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_3
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_4
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_4=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_4
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_5
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_5=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_5
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_6
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_6=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_6
ARG VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_10
ENV VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_10=$VITE_COSMOS_VOUCHERS_BUNDLE_PACKAGE_10

# Firebase Keys
ARG VITE_FIREBASE_API_KEY
ENV VITE_FIREBASE_API_KEY=$VITE_FIREBASE_API_KEY
ARG VITE_FIREBASE_AUTH_DOMAIN
ENV VITE_FIREBASE_AUTH_DOMAIN=$VITE_FIREBASE_AUTH_DOMAIN
ARG VITE_FIREBASE_PROJECT_ID
ENV VITE_FIREBASE_PROJECT_ID=$VITE_FIREBASE_PROJECT_ID
ARG VITE_FIREBASE_STORAGE_BUCKET
ENV VITE_FIREBASE_STORAGE_BUCKET=$VITE_FIREBASE_STORAGE_BUCKET
ARG VITE_FIREBASE_MESSAGING_SENDER_ID
ENV VITE_FIREBASE_MESSAGING_SENDER_ID=$VITE_FIREBASE_MESSAGING_SENDER_ID
ARG VITE_FIREBASE_APP_ID
ENV VITE_FIREBASE_APP_ID=$VITE_FIREBASE_APP_ID
ARG VITE_FIREBASE_MEASUREMENT_ID
ENV VITE_FIREBASE_MEASUREMENT_ID=$VITE_FIREBASE_MEASUREMENT_ID

RUN npm run build:railway






# 프로덕션 의존성만 설치 (루트)
# 주의: devDependencies 제거하지만 서버 실행에는 문제없음
WORKDIR /app
RUN npm install --production --omit=dev

# 포트 노출 (Railway가 자동으로 PORT 환경 변수를 설정하므로 EXPOSE는 참고용)
EXPOSE 8080

# 서버 시작
CMD ["node", "server.js"]